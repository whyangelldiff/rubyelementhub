    -- Cria os Drawing objects para um player (sistema Square do Shark)
    local function CreateGameEsp(plr)
        if GameEspObjects[plr] then return end
        local box  = Drawing.new("Square")
        box.Thickness = 1.5
        box.Filled    = false
        box.Visible   = false
    
        local nameL = Drawing.new("Text")
        nameL.Size        = 13
        nameL.Outline     = true
        nameL.OutlineColor= Color3.new(0,0,0)
        nameL.Center      = true
        nameL.Visible     = false
    
        local hpL = Drawing.new("Text")
        hpL.Size        = 11
        hpL.Outline     = true
        hpL.OutlineColor= Color3.new(0,0,0)
        hpL.Center      = true
        hpL.Visible     = false
    
        local distL = Drawing.new("Text")
        distL.Size        = 11
        distL.Outline     = true
        distL.OutlineColor= Color3.new(0,0,0)
        distL.Center      = true
        distL.Visible     = false
    
        GameEspObjects[plr] = { box=box, nameL=nameL, hpL=hpL, distL=distL }
    end
    
    local function DestroyGameEsp(plr)
        local obj = GameEspObjects[plr]
        if not obj then return end
        for _, d in pairs(obj) do pcall(function() d:Remove() end) end
        GameEspObjects[plr] = nil
    end
    
    local function HideGameEsp(plr)
        local obj = GameEspObjects[plr]
        if not obj then return end
        for _, d in pairs(obj) do d.Visible = false end
    end
    
    local function UpdateGameEsp(plr)
        local obj = GameEspObjects[plr]
        if not obj then return end
    
        if IgnoredPlayers[plr.Name] then HideGameEsp(plr) return end
        if plr.Team and IgnoredTeams[plr.Team.Name] then HideGameEsp(plr) return end
    
        local char = plr.Character
        if not char then HideGameEsp(plr) return end
    
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then HideGameEsp(plr) return end
    
        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen then HideGameEsp(plr) return end
    
        -- Tamanho do box baseado na distância (mesmo cálculo do Shark)
        local sizeY = (Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0,3,0)).Y
                     - Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0,3,0)).Y)
        local boxW  = sizeY * 1.5
        local boxH  = sizeY * 2
    
        local col = GetTeamColor(plr)
    
        -- Box (Square)
        obj.box.Size     = Vector2.new(boxW, boxH)
        obj.box.Position = Vector2.new(pos.X - boxW/2, pos.Y - boxH/2)
        obj.box.Color    = col
        obj.box.Visible  = true
    
        local topY = pos.Y - boxH/2
        local cx   = pos.X
    
        -- Username
        obj.nameL.Text     = plr.Name
        obj.nameL.Position = Vector2.new(cx, topY - 38)
        obj.nameL.Color    = Color3.new(1,1,1)
        obj.nameL.Visible  = true
    
        -- HP (verde → amarelo → vermelho)
        local hp    = math.floor(hum.Health)
        local maxhp = math.floor(hum.MaxHealth)
        local ratio = maxhp > 0 and (hp / maxhp) or 0
        obj.hpL.Text     = hp .."/".. maxhp .." HP"
        obj.hpL.Position = Vector2.new(cx, topY - 25)
        obj.hpL.Color    = Color3.fromRGB(
            math.floor((1 - ratio) * 255),
            math.floor(ratio * 210),
            50
        )
        obj.hpL.Visible = true
    
        -- Distância até meu personagem
        local myChar = Player.Character
        local dist = 0
        if myChar then
            local myHRP = myChar:FindFirstChild("HumanoidRootPart")
            if myHRP then
                dist = math.floor((myHRP.Position - hrp.Position).Magnitude)
            end
        end
        obj.distL.Text     = dist .."m"
        obj.distL.Position = Vector2.new(cx, topY - 13)
        obj.distL.Color    = Color3.fromRGB(200,200,200)
        obj.distL.Visible  = true
    end
    
