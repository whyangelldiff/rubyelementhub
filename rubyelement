    -- Retorna o inimigo mais próximo dentro do círculo
    local function GetNearestInCircle(circleCenter, radius)
        local best, bestDist = nil, math.huge
        local vp = workspace.CurrentCamera.ViewportSize
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == Player then continue end
            if AimIgnoredPlayers[plr.Name] then continue end
            if plr.Team and AimIgnoredTeams[plr.Team.Name] then continue end
            local char = plr.Character
            if not char then continue end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum or hum.Health <= 0 then continue end
            local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            if not onScreen then continue end
            local sp2 = Vector2.new(screenPos.X, screenPos.Y)
            local dist = (sp2 - circleCenter).Magnitude
            if dist <= radius and dist < bestDist then
                bestDist = dist
                best     = plr
            end
        end
        return best
    end
    
