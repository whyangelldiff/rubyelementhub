    -- Fly logic: direção baseada no analógico + inclinação da câmera
    local function StartFly()
        flyEnabled = true
        local char = Player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
    
        hum.PlatformStand = true
    
        flyBV = Instance.new("BodyVelocity")
        flyBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        flyBV.Velocity = Vector3.zero
        flyBV.Parent   = hrp
    
        local BG = Instance.new("BodyGyro")
        BG.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        BG.P         = 1e4
        BG.Parent    = hrp
    
        flyConn = RunService.Heartbeat:Connect(function()
            if not flyEnabled then
                if flyBV and flyBV.Parent then flyBV:Destroy() end
                if BG and BG.Parent then BG:Destroy() end
                if hum then hum.PlatformStand = false end
                flyConn:Disconnect()
                flyConn = nil
                return
            end
    
            local camCF  = workspace.CurrentCamera.CFrame
            local look   = camCF.LookVector   -- direção que a câmera aponta (inclui Y)
            local right  = camCF.RightVector
    
            -- Analógico: MoveDirection é normalizado no plano XZ pelo Roblox
            -- md.Z < 0 = pra frente, md.Z > 0 = pra trás
            -- md.X > 0 = direita,    md.X < 0 = esquerda
            local md = hum.MoveDirection
    
            local vel = Vector3.zero
    
            if md.Magnitude > 0.05 then
                -- Eixo frontal: usa o LookVector COMPLETO da câmera (com Y)
                -- Assim arrastar pra frente + câmera pra cima = sobe
                -- Arrastar pra frente + câmera pra baixo = desce
                local fwd = look  -- inclui inclinação vertical
    
                -- Eixo lateral: usa só o componente horizontal do RightVector
                local rgt = Vector3.new(right.X, 0, right.Z)
                if rgt.Magnitude > 0 then rgt = rgt.Unit end
    
                -- md.Z negativo = frente, positivo = trás
                -- md.X positivo = direita, negativo = esquerda
                vel = (fwd * -md.Z) + (rgt * md.X)
            end
    
            if vel.Magnitude > 0.01 then
                flyBV.Velocity = vel.Unit * flySpeed
            else
                flyBV.Velocity = Vector3.zero
            end
    
            BG.CFrame = camCF
        end)
    end
    
    local function StopFly()
        flyEnabled = false
        -- flyConn se auto-desconecta no heartbeat acima
    end
    
