        end
        aimTeamItems = {}
    
        local teamNames = {}
        local ok, svc = pcall(function() return game:GetService("Teams") end)
        if ok and svc then
            for _, t in ipairs(svc:GetTeams()) do
                table.insert(teamNames, t.Name)
            end
        end
        if #teamNames == 0 then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Team then
                    local dup = false
                    for _, n in ipairs(teamNames) do if n == plr.Team.Name then dup=true break end end
                    if not dup then table.insert(teamNames, plr.Team.Name) end
                end
            end
        end
        if #teamNames == 0 then table.insert(teamNames, "Sem times detectados") end
    
        for _, tn in ipairs(teamNames) do
            local row = Instance.new("Frame")
            row.Size             = UDim2.new(1,-10,0,28)
            row.BackgroundColor3 = Color3.fromRGB(30,30,30)
            row.BorderSizePixel  = 0
            row.Parent           = AimTeamDropdown
            Instance.new("UICorner", row).CornerRadius = UDim.new(0,7)
    
            local rl = Instance.new("TextLabel")
            rl.BackgroundTransparency = 1
            rl.Size           = UDim2.new(1,-36,1,0)
            rl.Position       = UDim2.new(0,10,0,0)
            rl.Text           = tn
            rl.Font           = Enum.Font.Gotham
            rl.TextSize       = 10
            rl.TextColor3     = Color3.new(1,1,1)
            rl.TextXAlignment = Enum.TextXAlignment.Left
            rl.Parent         = row
    
            local dot = Instance.new("Frame")
            dot.Size             = UDim2.fromOffset(10,10)
            dot.Position         = UDim2.new(1,-20,0.5,-5)
            dot.BackgroundColor3 = AimIgnoredTeams[tn] and Color3.fromRGB(180,0,0) or Color3.fromRGB(40,40,40)
            dot.BorderSizePixel  = 0
            dot.Parent           = row
            Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
    
            local btn = Instance.new("TextButton")
            btn.Size                 = UDim2.new(1,0,1,0)
            btn.BackgroundTransparency = 1
            btn.Text                 = ""
            btn.Parent               = row
    
            aimTeamItems[tn] = {row=row, dot=dot}
    
            btn.MouseButton1Click:Connect(function()
        PlayClickSound()
                if AimIgnoredTeams[tn] then
