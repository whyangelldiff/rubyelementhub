local function getRGB(offset)
    offset = offset or 0
    local t = tick() * 0.8 + offset
    return Color3.new(
        math.abs(math.sin(t)),
        math.abs(math.sin(t + 2*math.pi/3)),
        math.abs(math.sin(t + 4*math.pi/3))
    )
end

